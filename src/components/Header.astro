---
import { brand } from '../config/brand';
import HeaderLink from './HeaderLink.astro';
import IssueBadge from './IssueBadge.astro';
---

<header class="site-header">
	<nav class="masthead" aria-label="Navigasi utama">
		<a class="brand-lockup" href="/" aria-label={`${brand.name}, beranda`}>
			<span class="brand-name">{brand.name}</span>
			<IssueBadge />
		</a>

		<div class="desktop-nav">
			{brand.nav.map((item) => <HeaderLink href={item.href}>{item.label}</HeaderLink>)}
		</div>

		<details class="mobile-nav">
			<summary aria-label="Buka navigasi">Menu</summary>
			<div class="mobile-panel">
				{brand.nav.map((item) => <HeaderLink href={item.href}>{item.label}</HeaderLink>)}
			</div>
		</details>
	</nav>
</header>

<style>
	.site-header {
		position: sticky;
		top: 0;
		z-index: 50;
		background: color-mix(in oklch, var(--color-paper) 90%, transparent);
		border-bottom: 1px solid var(--color-line);
		backdrop-filter: blur(16px);
	}

	.masthead {
		width: min(100% - 2rem, var(--wide));
		min-height: 4.5rem;
		margin-inline: auto;
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1rem;
	}

	.brand-lockup {
		min-height: 44px;
		display: flex;
		align-items: baseline;
		gap: 1rem;
		text-decoration: none;
	}

	.brand-name {
		font-family: var(--font-display), Georgia, serif;
		font-size: 1.65rem;
		font-weight: 650;
		letter-spacing: -0.05em;
	}

	.desktop-nav {
		display: flex;
		align-items: center;
		gap: 1.5rem;
	}

	.desktop-nav :global(a) {
		min-height: 44px;
		display: inline-flex;
		align-items: center;
		font-family: var(--font-utility), ui-monospace, monospace;
		font-size: 0.73rem;
		font-weight: 600;
		letter-spacing: 0.08em;
		text-decoration: none;
		text-transform: uppercase;
	}

	.mobile-nav {
		display: none;
	}

	@media (max-width: 720px) {
		.masthead {
			width: min(100% - 1.25rem, var(--wide));
			min-height: 4rem;
		}

		.desktop-nav,
		.brand-lockup :global(.issue-badge) {
			display: none;
		}

		.mobile-nav {
			display: block;
			position: relative;
		}

		.mobile-nav summary {
			min-height: 44px;
			display: grid;
			place-items: center;
			font-family: var(--font-utility), ui-monospace, monospace;
			font-size: 0.73rem;
			text-transform: uppercase;
			cursor: pointer;
		}

		.mobile-panel {
			position: absolute;
			top: calc(100% + 0.35rem);
			right: 0;
			min-width: 11rem;
			padding: 0.6rem;
			display: grid;
			background: var(--color-paper);
			border: 1px solid var(--color-line);
			border-radius: var(--radius-card);
			box-shadow: 0 1rem 3rem color-mix(in oklch, var(--color-ink) 14%, transparent);
		}

		.mobile-panel :global(a) {
			min-height: 44px;
			display: flex;
			align-items: center;
			padding-inline: 0.8rem;
			text-decoration: none;
		}
	}
</style>
