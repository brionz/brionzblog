---
import AboutHeroImage from '../assets/blog-placeholder-about.jpg';
import SiteLayout from '../layouts/SiteLayout.astro';
import { brand } from '../config/brand';
import { Image } from 'astro:assets';
---

<SiteLayout title="Tentang" description={brand.author.bio} image={AboutHeroImage} wide>
	<header class="about-hero">
		<div class="about-copy">
			<p class="utility-label">Tentang jurnal</p>
			<h1>{brand.name}</h1>
			<p class="lead">{brand.tagline}.</p>
			<p class="deck">{brand.description}</p>
		</div>
		<figure class="about-media">
			<Image src={AboutHeroImage} width={900} height={1100} alt="" />
		</figure>
	</header>

	<section class="about-body prose">
		<h2>Siapa yang menulis</h2>
		<p>
			<strong>{brand.author.name}</strong>
			{brand.author.role ? ` · ${brand.author.role}` : ''}
		</p>
		<p>{brand.author.bio}</p>

		<h2>Apa yang akan Anda temukan</h2>
		<p>
			Esai panjang—bukan opini kilat. Tulisan yang bisa diselesaikan dalam satu duduk, lalu dibuka
			lagi sebulan kemudian dan masih terasa baru.
		</p>
		<p>
			Untuk mengganti nama, warna, navigasi, dan detail penulis, edit
			<code>src/config/brand.ts</code>. Satu file itu mengendalikan header, hero, footer, dan meta
			tags.
		</p>

		{
			brand.author.email && (
				<p>
					Sapa saya: <a href={`mailto:${brand.author.email}`}>{brand.author.email}</a>
				</p>
			)
		}
	</section>
</SiteLayout>

<style>
	.about-hero {
		display: grid;
		grid-template-columns: 1.1fr 0.9fr;
		gap: 2.5rem;
		align-items: end;
		padding: clamp(2.5rem, 5vw, 4rem) 0 clamp(2rem, 4vw, 3.5rem);
	}

	.about-copy h1 {
		margin: 0.5rem 0 1rem;
		font-size: clamp(3rem, 8vw, 5.5rem);
		line-height: 0.92;
	}

	.lead {
		margin: 0 0 1rem;
		font-family: var(--font-display), Georgia, serif;
		font-size: clamp(1.35rem, 2.5vw, 1.85rem);
		font-style: italic;
		line-height: 1.25;
		letter-spacing: -0.02em;
	}

	.deck {
		margin: 0;
		max-width: 38ch;
		color: var(--color-muted);
		font-size: 1.05rem;
		line-height: 1.55;
	}

	.about-media {
		margin: 0;
		overflow: hidden;
		border-radius: var(--radius-card);
		aspect-ratio: 4 / 5;
	}

	.about-media img {
		width: 100%;
		height: 100%;
		object-fit: cover;
	}

	.about-body {
		padding: 2.5rem 0 3rem;
		border-top: 1px solid var(--color-line);
	}

	.about-body h2 {
		margin-top: 2rem;
	}

	@media (max-width: 820px) {
		.about-hero {
			grid-template-columns: 1fr;
		}

		.about-media {
			order: -1;
			max-height: 22rem;
			aspect-ratio: 16 / 10;
		}
	}
</style>
